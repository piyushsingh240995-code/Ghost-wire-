rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email == 'piyushsingh240995@gmail.com' && request.auth.token.email_verified == true; 
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isNotBanned(userId) {
      // Avoid recursive get() if possible, but for banning we need it.
      // We check if the user document says isBanned: true.
      return !exists(/databases/$(database)/documents/users/$(userId)) || 
             get(/databases/$(database)/documents/users/$(userId)).data.get('isBanned', false) == false;
    }

    // USER RULES
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == userId &&
               data.displayName is string && data.displayName.size() <= 50 &&
               data.username is string && data.username.size() <= 30 &&
               data.username.matches('^[a-z0-9_]+$');
      }

      allow read: if isSignedIn();
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().get('isAdmin', false) == false &&
                    incoming().get('isBanned', false) == false;
                    
      allow update: if (isOwner(userId) || isAdmin()) && (
        // Action: Profile Update
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['username', 'displayName', 'photoURL', 'ghostMode', 'soundEnabled', 'autoPurge', 'lastSeen', 'publicKey']) && isValidUser(incoming())) ||
        // Action: Admin Operations
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['isBanned', 'isAdmin']))
      );
    }

    // CONVERSATION RULES
    match /conversations/{convId} {
      function isValidConversation(data) {
        return data.participants is list && data.participants.size() >= 2 && data.participants.size() <= 10;
      }

      allow create: if isSignedIn() && isValidConversation(incoming()) && request.auth.uid in incoming().participants;
      
      // allow list: resource.data.participants contains auth.uid
      allow list: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow get: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants && (
        incoming().diff(existing()).affectedKeys().hasAny(['lastMessage', 'updatedAt', 'unreadCount', 'isEphemeral', 'typing', 'participantInfo'])
      );
      
      allow delete: if isSignedIn() && request.auth.uid in resource.data.participants;
    }

    // MESSAGE RULES
    match /conversations/{convId}/messages/{msgId} {
      function isParticipant(cid) {
        return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(cid)).data.participants;
      }

      function isValidMessage(data) {
        return data.senderId == request.auth.uid &&
               data.conversationId == convId &&
               data.content is string && data.content.size() <= 10000;
      }

      allow read: if isParticipant(convId);
      allow create: if isParticipant(convId) && isValidMessage(incoming());
      allow update: if isParticipant(convId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['seen', 'reactions'])
      );
      allow delete: if isParticipant(convId) && existing().senderId == request.auth.uid;
    }

    // PRIVATE KEYS (IRON VAULT)
    match /private_keys/{userId} {
      allow get, create, update: if isOwner(userId);
    }

    // ULTRON HISTORY
    match /ultron_history/{userId} {
      allow get, create, update: if isOwner(userId);
    }
  }
}
